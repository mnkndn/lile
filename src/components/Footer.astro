---
/* Footer Section — Screen 7
   Light bg, content left, illustration right, contact info */
---

<section id="contact" class="w-screen relative bg-brand-light py-16">
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-10 w-full max-w-7xl mx-auto px-8 md:px-[5vw]">

    <!-- Left: Tagline + CTA + Contact -->
    <div class="flex flex-col items-start">

      <!-- Tagline -->
      <h2 class="font-heading text-5xl md:text-section font-bold text-brand-navy mb-4 md:mb-0 leading-tight">
        Learn<span class="text-brand-accent">.</span><br />Practice<span class="text-brand-accent">.</span><br />Innovate<span class="text-brand-accent">.</span>
      </h2>

      <!-- CTA -->
      <a href="https://www.google.com" class="btn-primary mt-12 mb-8">
        Apply Now
      </a>

      <!-- Contact -->
      <div class="flex flex-col gap-5 md:gap-4">
        <p class="font-body font-bold uppercase tracking-widest text-base md:text-sm text-brand-black">
          Contact
        </p>

        <!-- Email -->
        <div class="flex items-center gap-3 text-brand-black">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-5 md:h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <a href="mailto:lile.academy@gmail.com" class="font-body text-lg md:text-base hover:text-brand-teal transition-colors">
            lile.academy@gmail.com
          </a>
        </div>

        <!-- Phone -->
        <div class="flex items-center gap-3 text-brand-black">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-5 md:h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span class="font-body text-lg md:text-base">
            +91 9361736597 (or) +91 7639300725
          </span>
        </div>
      </div>
    </div>

    <!-- Right: Illustration -->
    <div class="hidden md:flex items-center justify-center flex-shrink-0">
      <img
        src="/Studying-rafiki.svg"
        alt="Student learning online illustration"
        class="w-80 lg:w-96 object-contain"
      />
    </div>
  </div>
</section>
