---
/* Summer Classes Section — Screen 3
   Light bg, image left, heading + class tags right */

const classes = [
  'Art and Craft',
  'Home Economics',
  'STEM',
  'Maths Basics',
  'Phonics',
  'Spoken English',
  'Yoga and Fitness',
];
---

<section id="classes" class="section-screen bg-brand-light">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center w-full max-w-7xl mx-auto px-8 md:px-[5vw]">

    <!-- Image Column (hidden on mobile) -->
    <div class="hidden md:flex items-center justify-center">
      <div class="w-full max-w-md aspect-[4/3] overflow-hidden rounded-lg">
        <!-- Placeholder: replace with actual classes image -->
        <img
          src="/summer_classes.jpeg"
          alt="Children doing art and craft"
          class="w-full h-full object-cover bg-gray-200"
        />
      </div>
    </div>

    <!-- Content Column -->
    <div class="flex flex-col items-center md:items-start">

      <h2 class="font-heading font-bold text-3xl md:text-section text-brand-navy mb-8 md:mb-14">
        Summer <span class="hidden md:inline"><br /></span>Classes
      </h2>

      <!-- Tags Grid -->
      <div class="flex flex-col md:flex-row md:flex-wrap gap-4 md:gap-3 w-full max-w-sm md:max-w-md items-center">
        {classes.map((cls, i) => (
          <span
            class:list={[
              'class-tag w-full md:w-auto text-center hover:opacity-90 transition-opacity duration-200 cursor-pointer',
              i % 2 === 0 ? 'bg-teal-gradient' : 'bg-teal-gradient-dark',
            ]}
          >
            {cls}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
