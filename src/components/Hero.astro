---
/* Hero Section — Screen 1
   Light bg, centered logo + heading + CTA */
---

<section id="home" class="section-screen bg-brand-light pt-32 pb-12 mb-12 md:pt-10 md:pb-0 md:mb-0 md:!min-h-[90vh]">
  <div class="flex flex-col items-center justify-center text-center px-6 w-full max-w-5xl mx-auto relative z-10">

    <!-- Main Heading -->
    <h1 class="font-heading text-4xl md:text-hero font-bold text-brand-navy mb-6 md:mb-10">
      <span class="text-brand-navy">Li</span><span class="text-brand-navy">ttle </span><span class="text-brand-accent">Le</span><span class="text-brand-accent">aders</span><br /><span class="text-brand-navy">Academy</span>
    </h1>

    <!-- CTA -->
    <a href="https://www.google.com" class="btn-primary px-10 py-4 text-sm md:px-14 md:py-5 md:text-base">
      Apply Now
    </a>

    <!-- Download Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 sm:gap-8 mt-6 sm:mt-10">
      <a href="/Lily-Academy-Brochure.pdf" download class="btn-outline inline-flex items-center gap-2 px-6 py-2 text-xs sm:px-10 sm:py-4 sm:text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V3" />
        </svg>
        Brochure
      </a>
      <a href="/Lily-Academy-Curriculum.pdf" download class="btn-outline inline-flex items-center gap-2 px-6 py-2 text-xs sm:px-10 sm:py-4 sm:text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V3" />
        </svg>
        Curriculum
      </a>
    </div>
  </div>
</section>
